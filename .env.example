# ---------------------------------------------------------------------------
# SOXL/SOXS Trading Bot — environment configuration
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Alpaca ---------------------------------------------------------------
# Paper trading keys (https://alpaca.markets/ -> Paper account)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
# Set to "true" to trade against the LIVE account, "false" for paper.
ALPACA_PAPER=true

# --- Finnhub --------------------------------------------------------------
FINNHUB_API_KEY=your_finnhub_api_key

# --- Trading parameters ---------------------------------------------------
# Symbols are fixed to the SOXL/SOXS pair; listed here for clarity.
SYMBOL_LONG=SOXL
SYMBOL_SHORT=SOXS

# Risk controls
MAX_POSITION_PCT=0.10          # max position size as a fraction of equity
MAX_DAILY_LOSS_PCT=0.03        # halt trading after this daily loss fraction
MAX_TRADES_PER_DAY=10
ATR_STOP_MULTIPLIER=2.0        # stop-loss distance = ATR * this
ATR_TAKE_PROFIT_MULTIPLIER=3.0 # take-profit distance = ATR * this

# Strategy weighting (must sum to 1.0)
TECHNICAL_WEIGHT=0.7
SENTIMENT_WEIGHT=0.3

# Engine behavior
POLL_INTERVAL_SECONDS=60
CLOSE_AT_EOD=true              # flatten all positions before market close
USE_OPTIONS=false             # trade options instead of shares when true

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=trading_bot.log
LOG_MAX_BYTES=10485760         # 10 MB per file before rotation
LOG_BACKUP_COUNT=5
